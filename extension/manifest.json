{
    "manifest_version": 3,
    "name": "C-Block Origin",
    "version": "1.0",
    "description": "Faster WebAssembly C-powered Adblocker",
    "background": {
        "service_worker": "background.js"    
    },
    "permissions": [
        "declarativeNetRequest",
        "webRequest"        
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "web_accessible_resources": [
        {
            "resources": ["rules.txt"],
            "matches": ["<all_urls>"]
        }
    ]
}